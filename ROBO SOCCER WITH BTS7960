#include "BluetoothSerial.h"

BluetoothSerial ESP_BT;

// Pin Motor 18 19 22 23 |32 33 25 26
int IN1 = 18;//roda kiri MUNDUR
int IN2 = 19;//roda kiri MAJU
int IN3 = 25;//roda kanan MAJU
int IN4 = 26;//roda kanan MUNDUR

int REN = 13;
int LEM = 12;
int RAM = 15;
int LAN = 2 ;
 

char val;

void setup() {
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(REN, OUTPUT);
  pinMode(LEM, OUTPUT);
  pinMode(RAM, OUTPUT);
  pinMode(LAN, OUTPUT);

  digitalWrite(REN,HIGH);
  digitalWrite(LEM,HIGH);
  digitalWrite(RAM,HIGH);
  digitalWrite(LAN,HIGH);

  Serial.begin(115200);
  ESP_BT.begin("mamang_wesi");//OJO LALI DI GANTI YO TO!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  Serial.println("GASKEN~!");
}

void loop() 
{
  if (ESP_BT.available()) 
  {
    val = ESP_BT.read();
    Serial.print("Diterima: "); 
    Serial.println(val);

    switch (val) {
      case 'W'://MAJU
      digitalWrite(IN1, LOW);//roda kiri MUNDUR
      digitalWrite(IN2, HIGH);//roda kiri MAJU
      digitalWrite(IN3, HIGH);//roda kanan MAJU
      digitalWrite(IN4, LOW);//roda kanan MUNDUR
        break;
      case 'S'://MUNDUR
      digitalWrite(IN1, HIGH);//roda kiri MUNDUR
      digitalWrite(IN2, LOW);//roda kiri MAJU
      digitalWrite(IN3, LOW);//roda kanan MAJU
      digitalWrite(IN4, HIGH);//roda kanan MUNDUR

        break;
      case 'Q'://KANAN 
      digitalWrite(IN1, LOW);//roda kiri MUNDUR
      digitalWrite(IN2, HIGH);//roda kiri MAJU
      digitalWrite(IN3, LOW);//roda kanan MAJU
      digitalWrite(IN4, HIGH);//roda kanan MUNDUR
        break;
      case 'E'://kiri
      digitalWrite(IN1, HIGH);//roda kiri MUNDUR
      digitalWrite(IN2, LOW);//roda kiri MAJU
      digitalWrite(IN3, HIGH);//roda kanan MAJU
      digitalWrite(IN4, LOW);//roda kanan MUNDUR
        break;
      case 'A'://KIRI 1
      digitalWrite(IN1, LOW);//roda kiri MUNDUR
      digitalWrite(IN2, LOW);//roda kiri MAJU
      digitalWrite(IN3, HIGH);//roda kanan MAJU
      digitalWrite(IN4, LOW);//roda kanan MUNDUR
        break;
      case 'D'://KANAN 1
      digitalWrite(IN1, LOW);//roda kiri MUNDUR
      digitalWrite(IN2, HIGH);//roda kiri MAJU
      digitalWrite(IN3, LOW);//roda kanan MAJU
      digitalWrite(IN4, LOW);//roda kanan MUNDUR
        break;
      case 'X':
      digitalWrite(IN1, LOW);
      digitalWrite(IN2, LOW);
      digitalWrite(IN3, LOW);
      digitalWrite(IN4, LOW);
        break;
    }
  }
}
